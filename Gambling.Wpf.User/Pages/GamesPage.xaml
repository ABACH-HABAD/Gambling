<Page x:Class="Gambling.Wpf.User.Pages.GamesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Gambling.Wpf.User.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Выбор игры">

    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="/Resources/Images/Казино_2.jpg"/>
        </Grid.Background>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="2*"/>
        </Grid.RowDefinitions>
        <Border
            BorderThickness="5"
            CornerRadius="20"
            Margin="200,50,200,50" 
            Background="#FF9779AD" 
            BorderBrush="#FF160B3C">
            <TextBlock 
                Style="{StaticResource WelcomePageTextBlock}" 
                HorizontalAlignment="Center" 
                VerticalAlignment="Center" 
                FontWeight="Bold"
                Foreground="#FFFFA400">
            Выбери игру
            </TextBlock>
        </Border>
        <Grid Grid.Row="1" Margin="50">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Button 
                Style="{StaticResource GamePageButton}"
                x:Name="SlotsButton" 
                Click="SlotsButton_Click"
                Grid.Column="0">
                <Image Stretch="Fill" Source="/Resources/Images/Slots/SlotsMachine.png" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Button>
            <Button 
                Style="{StaticResource GamePageButton}"
                x:Name="BlackJackButton" 
                Grid.Column="1" 
                Click="BlackJackButton_Click">
                <Image Stretch="Fill" Source="/Resources/Images/Blackjack/CardsDeck.png"/>
            </Button>
            <Button 
                Style="{StaticResource GamePageButton}"
                x:Name="Roulette" 
                Grid.Column="2" 
                Click="Roulette_Click">
                <Image Stretch="Fill" Source="/Resources/Images/Roulette/Roulette.png"/>
            </Button>
        </Grid>
    </Grid>
</Page>
