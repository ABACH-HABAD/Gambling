<Page x:Class="Gambling.Wpf.User.Pages.Games.SlotsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Gambling.Wpf.User.Pages.Games"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Слоты" Loaded="Page_Loaded">
    <Page.Background>
        <ImageBrush ImageSource="/Resources/Images/Slots/bg-s.png"/>
    </Page.Background>
    <Grid Margin="200, 5, 200, 5">
        <Grid.RowDefinitions>
            <RowDefinition Height="7*"/>
            <RowDefinition Height="2*"/>
        </Grid.RowDefinitions>
        <Border
            BorderBrush="Black"
            BorderThickness="3"
            Margin="0,5,0,5">
            <Grid 
            x:Name="SlotsGrid" 
            ClipToBounds="True">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
            </Grid>
        </Border>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="30*"/>
                <ColumnDefinition Width="10*"/>
            </Grid.ColumnDefinitions>
            <Grid 
                Grid.Column="0"
                Margin="20">
                <Grid.Background>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="#FFD6ED4D" Offset="1"/>
                        <GradientStop Color="#FFA97A10" Offset="0"/>
                    </LinearGradientBrush>
                </Grid.Background>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <TextBlock 
                    Margin="5"
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Bottom" 
                    Foreground="Red"
                    FontFamily="Tw Cen MT Condensed Extra Bold" 
                    FontWeight="Bold"
                    FontSize="14">
                    Ставка:
                </TextBlock>
                <TextBox 
                    Grid.Row="1"
                    Width="200" 
                    Name="Bid" 
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Top" 
                    Margin="5" 
                    BorderBrush="#FFFF8000" 
                    Background="#FFFCFFC0" 
                    FontFamily="Goudy Stout" 
                    FontWeight="Bold"
                    FontSize="14">
                    <TextBox.SelectionBrush>
                        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                            <GradientStop Color="Red"/>
                            <GradientStop Color="#FFFFF500" Offset="1"/>
                        </LinearGradientBrush>
                    </TextBox.SelectionBrush>
                </TextBox>
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Button Style="{StaticResource BetButton}" Grid.Column="0" Content="100" Name="Bet100" Click="Bet100_Click"/>
                    <Button Style="{StaticResource BetButton}" Grid.Column="1" Content="500" Name="Bet500" Click="Bet500_Click"/>
                    <Button Style="{StaticResource BetButton}" Grid.Column="2" Content="1000" Name="Bet1000" Click="Bet1000_Click"/>
                    <Button Style="{StaticResource BetButton}" Grid.Column="3" Content="1/2 Bet" Name="HalfBet" Click="HalfBet_Click"/>
                    <Button Style="{StaticResource BetButton}" Grid.Column="4" Content="MAXBET" Name="MaxBet" Click="MaxBet_Click"/>
                    <Button Style="{StaticResource BetButton}" Grid.Column="5" Content="Сброс" Name="DropBet" Click="DropBet_Click"/>
                </Grid>
            </Grid>
            <Button 
                Style="{StaticResource GameButton}"
                BorderThickness="5"
                Grid.Column="1"
                x:Name="Spin" 
                Content="Крутить!"
                Click="Spin_Click" 
                Margin="20"
                Background="Red"
                BorderBrush="#FFFFF500"
                Foreground="#FFFFEA00"
                FontWeight="Bold"
                FontSize="16" 
                FontFamily="Tw Cen MT Condensed Extra Bold"/>
        </Grid>
    </Grid>
</Page>
