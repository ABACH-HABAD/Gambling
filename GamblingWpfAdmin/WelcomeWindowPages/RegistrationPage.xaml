<Page x:Class="GamblingWpfAdmin.WelcomeWindowPages.RegistrationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:GamblingWpfAdmin.WelcomeWindowPages"
      xmlns:easy="clr-namespace:EasyCaptcha.Wpf;assembly=EasyCaptcha.Wpf"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Страница Регистрации">

    <Grid>
        <StackPanel 
            Width="450"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">
            <Grid Style="{StaticResource WelcomePageGrid}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>
                <TextBlock
                    Text="Логин"
                    Style="{StaticResource WelcomePageTextBlock}"/>
                <TextBox 
                    Name="Login"
                    Grid.Column="1"
                    Style="{StaticResource WelcomePageTextBox}"/>
            </Grid>
            <Grid Style="{StaticResource WelcomePageGrid}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>
                <TextBlock 
                    Text="Пароль"
                    Style="{StaticResource WelcomePageTextBlock}"/>
                <PasswordBox 
                    Name="Password"
                    Grid.Column="1"
                    Style="{StaticResource WelcomePagePasswordBox}"/>
            </Grid>
            <Grid Style="{StaticResource WelcomePageGrid}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>
                <TextBlock 
                    Text="Повторите"
                    Style="{StaticResource WelcomePageTextBlock}"/>
                <PasswordBox 
                    Name="RepeatPassword"
                    Grid.Column="1"
                    Style="{StaticResource WelcomePagePasswordBox}"/>
            </Grid>
            <easy:Captcha Name="CaptchaPlace"/>
            <Grid Style="{StaticResource WelcomePageGrid}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>
                <TextBlock 
                    Text="Капча" 
                    Style="{StaticResource WelcomePageTextBlock}"/>
                <TextBox 
                    Name="CaptchaAnswer" 
                    Grid.Column="1"
                    Style="{StaticResource WelcomePageTextBox}"/>
            </Grid>
            <Button 
                Grid.Row="0" 
                x:Name="Registration" 
                Content="Зерегестрироваться" 
                Click="Registration_Click"
                Style="{StaticResource WelcomePageButton}"/>
            <Button 
                Grid.Row="1" 
                x:Name="Authorization" 
                Content="Уже есть аккаунт?" 
                Click="Authorization_Click"
                Style="{StaticResource WelcomePageButton}"/>
        </StackPanel>
    </Grid>
</Page>
