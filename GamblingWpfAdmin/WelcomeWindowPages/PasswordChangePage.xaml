<Page x:Class="GamblingWpfAdmin.WelcomeWindowPages.PasswordChangePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:GamblingWpfAdmin.WelcomeWindowPages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PasswordChangePage">

    <Grid>
        <StackPanel 
    Width="550"
    HorizontalAlignment="Center"
    VerticalAlignment="Center">
            <Grid Style="{StaticResource WelcomePageGrid}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="3*"/>
                </Grid.ColumnDefinitions>
                <TextBlock 
            Text="Старый пароль"
            Style="{StaticResource WelcomePageTextBlock}"/>
                <PasswordBox 
            Name="Password1" 
            Grid.Column="1"
            Style="{StaticResource WelcomePagePasswordBox}"/>
            </Grid>
            <Grid Style="{StaticResource WelcomePageGrid}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="3*"/>
                </Grid.ColumnDefinitions>
                <TextBlock 
            Text="Новый пароль"
            Style="{StaticResource WelcomePageTextBlock}"/>
                <PasswordBox 
            Name="Password2" 
            Grid.Column="1"
            Style="{StaticResource WelcomePagePasswordBox}"/>
            </Grid>
            <Grid Style="{StaticResource WelcomePageGrid}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="3*"/>
                </Grid.ColumnDefinitions>
                <TextBlock 
            Text="Повторите пароль"
            Style="{StaticResource WelcomePageTextBlock}"/>
                <PasswordBox 
            Name="Password3" 
            Grid.Column="1"
            Style="{StaticResource WelcomePagePasswordBox}"/>
            </Grid>
            <TextBlock x:Name="CaptchaPlace" Margin="0,5,0,5" FontSize="25" HorizontalAlignment="Center">
        Капча
            </TextBlock>
            <Grid Style="{StaticResource WelcomePageGrid}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="3*"/>
                </Grid.ColumnDefinitions>
                <TextBlock 
            Text="Капча"
            Style="{StaticResource WelcomePageTextBlock}"/>
                <TextBox 
            Name="CaptchaAnswer" 
            Grid.Column="1"
            Style="{StaticResource WelcomePageTextBox}"/>
            </Grid>
            <Button 
        Grid.Row="0" 
        x:Name="Authorization" 
        Content="Сменить пароль" 
        Style="{StaticResource WelcomePageButton}"/>
        </StackPanel>
    </Grid>
</Page>
