<Window x:Class="GamblingWpfAdmin.Windows.RoleChangeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GamblingWpfAdmin.Windows"
        mc:Ignorable="d"
        Title="Смена роли" Height="225" Width="475">
    <Window.Resources>
        <Style TargetType="ComboBoxItem">
            <Setter Property="FontSize" Value="25"/>
        </Style>
    </Window.Resources>
    <Grid>
        <Border
            CornerRadius="25"
            BorderThickness="3" 
            BorderBrush="Black" VerticalAlignment="Center" Margin="25,0,25,0">
            <StackPanel 
                Margin="15"
                VerticalAlignment="Center">
                <ComboBox Height="30" Margin="5">
                    <ComboBoxItem Content="Игрок" Tag="Player"/>
                    <ComboBoxItem Content="Спонсор" Tag="Sponsor"/>
                    <ComboBoxItem Content="Админ" Tag="Admin"/>
                    <ComboBoxItem Content="Заблокирован" Tag="Banned"/>
                </ComboBox>
                <Button Margin="5" Content="Подтвердить" Name="AcceptButton" Style="{StaticResource WelcomePageButton}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
