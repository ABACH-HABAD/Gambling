<Window x:Class="GamblingWpfAdmin.DataTablesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GamblingWpfAdmin"
        mc:Ignorable="d"
        Loaded="OnLoaded"
        Title="Окно админа" Height="800" Width="1360">
    <Grid>
        <TabControl>
            <TabItem Header="Пользователи">
                <DataGrid
                    Name="UsersDataGrid"
                    Style="{StaticResource CustomDataGridStyle}">
                    <DataGrid.Columns>
                        <DataGridTextColumn 
                                    Header="Id" 
                                    Binding="{Binding Id}"/>
                        <DataGridTextColumn 
                                    Header="Почта" 
                                    Binding="{Binding Email}"/>
                        <DataGridTextColumn 
                                    Header="Имя" 
                                    Binding="{Binding Name}"/>
                        <DataGridTextColumn 
                                    Header="Статус" 
                                    Binding="{Binding Status}"/>
                        <DataGridTextColumn 
                                    Header="Баланс" 
                                    Binding="{Binding Balance}"/>
                        <DataGridTextColumn 
                                    Header="Коефициент" 
                                    Binding="{Binding Coefficient}"/>
                        <DataGridTextColumn 
                                    Header="Шанс победы" 
                                    Binding="{Binding WinCount}"/>
                        <DataGridTextColumn 
                                    Header="Выиграно средств" 
                                    Binding="{Binding WinBalance}"/>
                        <DataGridTextColumn 
                                    Header="Проиграно средств" 
                                    Binding="{Binding LossBalance}"/>
                        <DataGridTemplateColumn Header="Заблокировать">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button 
                                        CommandParameter="{Binding}"
                                        Content="Заблокировать" 
                                        Style="{StaticResource DataTableButton}"
                                        Click="BanButton_Click">
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Пополнить баланс">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button 
                                        CommandParameter="{Binding}"
                                        Content="Редактировать" 
                                        Style="{StaticResource DataTableButton}"
                                        Click="AddToBalanceButton_Click">
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Сменить роль">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button 
                                        CommandParameter="{Binding}"
                                        Content="Сменить роль" 
                                        Style="{StaticResource DataTableButton}"
                                        Click="ChangeRoleButton_Click">
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Сбросить пароль">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button 
                                        CommandParameter="{Binding}"
                                        Content="Сброс" 
                                        Style="{StaticResource DataTableButton}"
                                        Click="ClearPasswordButton_Click">
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="Игры">
                <DataGrid
                    Name="GamesDataGrid"
                    Style="{StaticResource CustomDataGridStyle}">
                    <DataGrid.Columns>
                        <DataGridTextColumn 
                                    Header="Id" 
                                    Binding="{Binding Id}"/>
                        <DataGridTextColumn 
                                    Header="Тип игры" 
                                    Binding="{Binding StringGameType}"/>
                        <DataGridTextColumn 
                                    Header="ID Игрока" 
                                    Binding="{Binding Player}"/>
                        <DataGridTextColumn 
                                    Header="Ставка" 
                                    Binding="{Binding Bid}"/>
                        <DataGridTextColumn 
                                    Header="Итог" 
                                    Binding="{Binding StringIsWin}"/>
                        <DataGridTextColumn 
                                    Header="Выигрыш" 
                                    Binding="{Binding WinAmount}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="Сессии">
            </TabItem>
        </TabControl>
    </Grid>
</Window>
