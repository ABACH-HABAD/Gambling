<Window x:Class="GamblingWpfAdmin.MilkProduction"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GamblingWpfAdmin"
        mc:Ignorable="d"
        Title="Система управления производство и заказами" Height="450" Width="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" Text="Система управления производством и заказами" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>

        <!-- Вкладки с основными разделами -->
        <TabControl Grid.Row="1" Margin="0,10">

            <!-- Вкладка: Заказы покупателей -->
            <TabItem Header="📦 Заказы покупателей">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Кнопки управления -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="➕ Новый заказ" Width="120" Margin="0,0,10,0"/>
                        <Button Content="✏️ Редактировать" Width="120" Margin="0,0,10,0"/>
                        <Button Content="❌ Удалить" Width="100" Margin="0,0,10,0"/>
                        <Button Content="🖨️ Печать" Width="100"/>
                    </StackPanel>

                    <!-- Таблица заказов -->
                    <DataGrid Grid.Row="1" Name="dgOrders" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="№ заказа" Binding="{Binding Id}" Width="80"/>
                            <DataGridTextColumn Header="Дата" Binding="{Binding OrderDate, StringFormat='dd.MM.yyyy'}" Width="100"/>
                            <DataGridTextColumn Header="Заказчик" Binding="{Binding CounterpartyName}" Width="200"/>
                            <DataGridTextColumn Header="Сумма" Binding="{Binding TotalSum, StringFormat='N2'}" Width="100"/>
                            <DataGridTemplateColumn Header="Статус" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox SelectedItem="{Binding Status}" ItemsSource="{Binding Statuses}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Детали заказа -->
                    <GroupBox Grid.Row="2" Header="Состав заказа" Margin="0,10,0,0">
                        <DataGrid Name="dgOrderItems" AutoGenerateColumns="False" Height="150">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Продукт" Binding="{Binding ProductName}" Width="250"/>
                                <DataGridTextColumn Header="Кол-во" Binding="{Binding Quantity}" Width="80"/>
                                <DataGridTextColumn Header="Ед. изм." Binding="{Binding Unit}" Width="80"/>
                                <DataGridTextColumn Header="Цена" Binding="{Binding Price, StringFormat='N2'}" Width="80"/>
                                <DataGridTextColumn Header="Сумма" Binding="{Binding Sum, StringFormat='N2'}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </GroupBox>
                </Grid>
            </TabItem>

            <!-- Вкладка: Производство -->
            <TabItem Header="🏭 Производство">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="📋 Создать наряд" Width="130" Margin="0,0,10,0"/>
                        <Button Content="📊 Списать материалы" Width="140" Margin="0,0,10,0"/>
                        <Button Content="✅ Завершить производство" Width="150"/>
                    </StackPanel>

                    <DataGrid Grid.Row="1" Name="dgProduction" AutoGenerateColumns="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="№ наряда" Binding="{Binding Id}" Width="80"/>
                            <DataGridTextColumn Header="Дата" Binding="{Binding Date}" Width="100"/>
                            <DataGridTextColumn Header="Продукт" Binding="{Binding ProductName}" Width="200"/>
                            <DataGridTextColumn Header="План (шт)" Binding="{Binding PlannedQty}" Width="100"/>
                            <DataGridTextColumn Header="Факт (шт)" Binding="{Binding ActualQty}" Width="100"/>
                            <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <GroupBox Grid.Row="2" Header="Расход материалов по выбранному наряду" Margin="0,10,0,0">
                        <DataGrid Name="dgMaterialsUsed" AutoGenerateColumns="False" Height="150">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Материал" Binding="{Binding MaterialName}" Width="200"/>
                                <DataGridTextColumn Header="Норма" Binding="{Binding NormQty}" Width="80"/>
                                <DataGridTextColumn Header="Факт" Binding="{Binding ActualQty}" Width="80"/>
                                <DataGridTextColumn Header="Ед. изм." Binding="{Binding Unit}" Width="80"/>
                                <DataGridTextColumn Header="Отклонение" Binding="{Binding Deviation}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </GroupBox>
                </Grid>
            </TabItem>

            <!-- Вкладка: Номенклатура и цены -->
            <TabItem Header="📋 Номенклатура / Цены">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="400"/>
                    </Grid.ColumnDefinitions>

                    <GroupBox Header="Список продуктов и материалов" Grid.Column="0">
                        <DataGrid Name="dgProducts" AutoGenerateColumns="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Код" Binding="{Binding Code}" Width="100"/>
                                <DataGridTextColumn Header="Наименование" Binding="{Binding Name}" Width="250"/>
                                <DataGridTextColumn Header="Тип" Binding="{Binding Type}" Width="100"/>
                                <DataGridTextColumn Header="Ед. изм." Binding="{Binding Unit}" Width="80"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </GroupBox>

                    <GroupBox Header="Цены (актуальные)" Grid.Column="1" Margin="10,0,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="7*"/>
                                <RowDefinition Height="1*"/>
                            </Grid.RowDefinitions>
                            <DataGrid Name="dgPrices" AutoGenerateColumns="False" Margin="0,0,0,53">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Продукт" Binding="{Binding ProductName}" Width="180"/>
                                    <DataGridTextColumn Header="Цена" Binding="{Binding Price, StringFormat='N2'}" Width="80"/>
                                    <DataGridTextColumn Header="Дата" Binding="{Binding Date, StringFormat='dd.MM.yyyy'}" Width="100"/>
                                </DataGrid.Columns>
                            </DataGrid>
                            <Button Grid.Row="1" Content="✏️ Редактировать цены" HorizontalAlignment="Right" Margin="5" Width="137"/>
                        </Grid>
                    </GroupBox>
                </Grid>
            </TabItem>

            <!-- Вкладка: Контрагенты -->
            <TabItem Header="👥 Контрагенты">
                <Grid Margin="10">
                    <DataGrid Name="dgCounterparties" AutoGenerateColumns="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="80"/>
                            <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="250"/>
                            <DataGridTextColumn Header="ИНН" Binding="{Binding Inn}" Width="120"/>
                            <DataGridTextColumn Header="Адрес" Binding="{Binding Address}" Width="250"/>
                            <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="120"/>
                            <DataGridCheckBoxColumn Header="Продавец" Binding="{Binding IsSalesman}" Width="80"/>
                            <DataGridCheckBoxColumn Header="Покупатель" Binding="{Binding IsBuyer}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                        <Button Content="➕ Добавить" Width="100" Margin="0,0,10,0"/>
                        <Button Content="✏️ Редактировать" Width="100"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Вкладка: Спецификации -->
            <TabItem Header="📐 Спецификации (рецепты)">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="250"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <ListBox Name="lbSpecifications" Grid.Column="0" DisplayMemberPath="Name"/>

                    <DataGrid Name="dgSpecMaterials" Grid.Column="1" Margin="10,0,0,0" AutoGenerateColumns="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Материал" Binding="{Binding MaterialName}" Width="200"/>
                            <DataGridTextColumn Header="Количество" Binding="{Binding Quantity}" Width="100"/>
                            <DataGridTextColumn Header="Ед. изм." Binding="{Binding Unit}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Статус-бар -->
        <StatusBar Grid.Row="2" Margin="0,10,0,0">
            <StatusBarItem>
                <TextBlock Text="Готово. Подключение к БД: MilkProdDB"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="Пользователь: Администратор"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
