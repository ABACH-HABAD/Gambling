<Window x:Class="Gambling.Wpf.Admin.WelcomeWindowPages.UserBanWindow"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Gambling.Wpf.Admin.WelcomeWindowPages"
      mc:Ignorable="d" 
      d:DesignHeight="425" d:DesignWidth="650"
        ResizeMode="CanMinimize"
        Loaded="Window_Loaded"
      Title="Блокировака пользователя">

    <Grid>
        <Border
            CornerRadius="25"
            BorderThickness="3" 
            BorderBrush="Black" 
            HorizontalAlignment="Center"
            VerticalAlignment="Center">
            <StackPanel 
                Margin="15"
    Width="550"
    HorizontalAlignment="Center"
    VerticalAlignment="Center">
                <Grid Style="{StaticResource WelcomePageGrid}">
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <TextBlock 
            Text="Причина:"
            Style="{StaticResource WelcomePageTextBlock}"/>
                    <TextBox 
                        TextWrapping="Wrap"
                        FontSize="20"
                    Margin="5"
            Name="Reason" 
                    Grid.Row="1"
            Grid.Column="1"
             HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Height="100"/>
                </Grid>
                <Border
                    CornerRadius="10"
                    BorderThickness="2" 
                    BorderBrush="Black" 
                    Margin="0,5,0,5"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                    <TextBlock x:Name="CaptchaPlace" Margin="5" FontSize="25" HorizontalAlignment="Center">
        Капча
                    </TextBlock>
                </Border>
                <Grid Style="{StaticResource WelcomePageGrid}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="3*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock 
            Text="Капча"
            Style="{StaticResource WelcomePageTextBlock}"/>
                    <TextBox 
            Name="CaptchaAnswer" 
            Grid.Column="1"
            Style="{StaticResource WelcomePageTextBox}"/>
                </Grid>
                <Button 
        Grid.Row="0" 
        x:Name="Authorization" 
        Content="Заблокировать пользователя" 
        Style="{StaticResource WelcomePageButton}" Click="Authorization_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
