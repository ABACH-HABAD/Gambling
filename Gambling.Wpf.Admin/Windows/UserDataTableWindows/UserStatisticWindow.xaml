<Window x:Class="Gambling.Wpf.Admin.Windows.UserDataTableWindows.UserStatisticWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Gambling.Wpf.Admin.Windows.UserDataTableWindows"
        mc:Ignorable="d"
        Title="Статистика игрока" 
        ResizeMode="CanMinimize"
        Height="425" Width="600">
    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
        <Border
    Margin="10"
    Padding="10"
    BorderBrush="Black"
    BorderThickness="3"
    CornerRadius="25" HorizontalAlignment="Center">
            <StackPanel>
                <TextBlock
            Style="{StaticResource ProfileTextBlock}"
            HorizontalAlignment="Center">
            Статистика:
                </TextBlock>
                <StackPanel Orientation="Horizontal">
                    <RadioButton  
                Content="Всё" 
                Name="All"
                GroupName="GameTypes"
                Style="{StaticResource ProfileRadioButton}" 
                Checked="All_Checked"/>
                    <RadioButton  
                Content="Слоты" 
                Name="Slots"
                GroupName="GameTypes"
                Style="{StaticResource ProfileRadioButton}" 
                Checked="Slots_Checked"/>
                    <RadioButton  
                Content="Блэкджек" 
                Name="Blackjack"
                GroupName="GameTypes"
                Style="{StaticResource ProfileRadioButton}" 
                Checked="Blackjack_Checked"/>
                    <RadioButton  
                Content="Рулетка" 
                Name="Roulette"
                GroupName="GameTypes"
                Style="{StaticResource ProfileRadioButton}" 
                Checked="Roulette_Checked"/>
                </StackPanel>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource ProfileTextBlock}" Grid.Row="0" Grid.Column="1">
                        Количество:
                    </TextBlock>
                    <TextBlock Style="{StaticResource ProfileTextBlock}" Grid.Row="0" Grid.Column="2">
                Сумма:
                    </TextBlock>
                    <TextBlock Style="{StaticResource ProfileTextBlock}" Grid.Row="1" Grid.Column="0">
                 Победы:
                    </TextBlock>
                    <TextBlock 
                Style="{StaticResource ProfileTextBlock}" 
                Grid.Row="1"
                Grid.Column="1" 
                x:Name="WinCount">
                10
                    </TextBlock>
                    <TextBlock 
                Style="{StaticResource ProfileTextBlock}" 
                Grid.Row="1" 
                Grid.Column="2" 
                x:Name="WinBalance">
                500
                    </TextBlock>
                    <TextBlock Style="{StaticResource ProfileTextBlock}" Grid.Row="2" Grid.Column="0">
                  Поражения:
                    </TextBlock>
                    <TextBlock 
                Style="{StaticResource ProfileTextBlock}"
                Grid.Row="2"
                Grid.Column="1"
                x:Name="LossCount">
                50
                    </TextBlock>
                    <TextBlock 
                Style="{StaticResource ProfileTextBlock}" 
                Grid.Row="2" 
                Grid.Column="2" 
                x:Name="LossBalance">
                50000
                    </TextBlock>
                    <TextBlock Style="{StaticResource ProfileTextBlock}" Grid.Row="3" Grid.Column="0">
                  Итого:
                    </TextBlock>
                    <TextBlock 
                Style="{StaticResource ProfileTextBlock}"
                Grid.Row="3"
                Grid.Column="1"
                Name="WinFrequency">
                 % Побед: 67%
                    </TextBlock>
                    <TextBlock 
                Style="{StaticResource ProfileTextBlock}"

                Grid.Row="3"
                Grid.Column="2"
                Name="TotalBalance">
                 -49950
                    </TextBlock>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</Window>
