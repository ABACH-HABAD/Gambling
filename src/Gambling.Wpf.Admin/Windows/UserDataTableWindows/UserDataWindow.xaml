<Window x:Class="Gambling.Wpf.Admin.Windows.UserDataTableWindows.UserDataWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Gambling.Wpf.Admin.Windows.UserDataTableWindows"
        mc:Ignorable="d"
        Title="Таблица данных пользователя" 
        ResizeMode="CanMinimize"
        Height="450" Width="800">
    <Window.Resources>
        <Style TargetType="Border">
            <Setter Property="BorderBrush" Value="Black"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>
    </Window.Resources>
    <Grid>
        <Border Margin="25">
            <Grid >
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Border Grid.Row="0" Grid.Column="0">
                    <TextBlock Text="Id:" Style="{StaticResource WelcomePageTextBlock}"/>
                </Border>
                <Border Grid.Row="1" Grid.Column="0">
                    <TextBlock Text="Почта:" Style="{StaticResource WelcomePageTextBlock}"/>
                </Border>
                <Border Grid.Row="2" Grid.Column="0">
                    <TextBlock Text="Имя:" Style="{StaticResource WelcomePageTextBlock}"/>
                </Border>
                <Border Grid.Row="3" Grid.Column="0">
                    <TextBlock Text="Роль:" Style="{StaticResource WelcomePageTextBlock}"/>
                </Border>
                <Border Grid.Row="4" Grid.Column="0">
                    <TextBlock Text="Статус:" Style="{StaticResource WelcomePageTextBlock}"/>
                </Border>
                <Border Grid.Row="5" Grid.Column="0">
                    <TextBlock Text="Баланс:" Style="{StaticResource WelcomePageTextBlock}"/>
                </Border>
                <Border Grid.Row="6" Grid.Column="0">
                    <TextBlock Text="Коэфициент:" Style="{StaticResource WelcomePageTextBlock}"/>
                </Border>
                <Border Grid.Row="7" Grid.Column="0">
                    <TextBlock Text="Статистика игр:" Style="{StaticResource WelcomePageTextBlock}"/>
                </Border>

                <Border Grid.Row="0" Grid.Column="1">
                    <TextBlock Name="Id" Style="{StaticResource WelcomePageTextBlock}"/>
                </Border>
                <Border Grid.Row="1" Grid.Column="1">
                    <TextBlock Name="Email" Style="{StaticResource WelcomePageTextBlock}"/>
                </Border>
                <Border Grid.Row="2" Grid.Column="1">
                    <TextBlock Name="DisplayName" Style="{StaticResource WelcomePageTextBlock}"/>
                </Border>
                <Border Grid.Row="3" Grid.Column="1">
                    <TextBlock Name="Role" Style="{StaticResource WelcomePageTextBlock}"/>
                </Border>
                <Border Grid.Row="4" Grid.Column="1">
                    <TextBlock Name="IsBlocked" Style="{StaticResource WelcomePageTextBlock}"/>
                </Border>
                <Border Grid.Row="5" Grid.Column="1">
                    <TextBlock Name="Balance" Style="{StaticResource WelcomePageTextBlock}"/>
                </Border>
                <Border Grid.Row="6" Grid.Column="1">
                    <TextBlock Name="Coefficient" Style="{StaticResource WelcomePageTextBlock}"/>
                </Border>
                <Border Grid.Row="7" Grid.Column="1">
                    <Button x:Name="StatisticButton" Content="Посмотреть" FontSize="20" Style="{StaticResource DataTableButton}" Margin="5" Click="StatisticButton_Click"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
