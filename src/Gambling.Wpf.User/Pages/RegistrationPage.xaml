<Page x:Class="Gambling.Wpf.User.Pages.RegistrationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Gambling.Wpf.User.Pages"
      xmlns:easy="clr-namespace:EasyCaptcha.Wpf;assembly=EasyCaptcha.Wpf"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Страница Регистрации">

    <Grid>
        <Border
            CornerRadius="25"
            BorderThickness="3" 
            BorderBrush="Black" 
            HorizontalAlignment="Center"
            VerticalAlignment="Center">
            <StackPanel 
                Margin="15"
            Width="450"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">
                <Grid Style="{StaticResource WelcomePageGrid}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock
                    Text="Логин"
                    Style="{StaticResource WelcomePageTextBlock}"/>
                    <TextBox 
                    Name="Login"
                    Grid.Column="1"
                    Style="{StaticResource WelcomePageTextBox}"/>
                </Grid>
                <Grid Style="{StaticResource WelcomePageGrid}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock 
                    Text="Пароль"
                    Style="{StaticResource WelcomePageTextBlock}"/>
                    <PasswordBox 
                    Name="Password"
                    Grid.Column="1"
                    Style="{StaticResource WelcomePagePasswordBox}"/>
                </Grid>
                <Grid Style="{StaticResource WelcomePageGrid}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock 
                    Text="Повторите"
                    Style="{StaticResource WelcomePageTextBlock}"/>
                    <PasswordBox 
                    Name="RepeatPassword"
                    Grid.Column="1"
                    Style="{StaticResource WelcomePagePasswordBox}"/>
                </Grid>
                <Border
                    CornerRadius="10"
                    BorderThickness="2" 
                    BorderBrush="Black" 
                    Margin="0,5,0,5"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center" 
                ClipToBounds="True"
                >
                    <easy:Captcha Name="CaptchaPlace" FontWeight="Bold" Margin="5"/>
                </Border>
                <Grid Style="{StaticResource WelcomePageGrid}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock 
                    Text="Капча" 
                    Style="{StaticResource WelcomePageTextBlock}"/>
                    <TextBox 
                    Name="CaptchaAnswer" 
                    Grid.Column="1"
                    Style="{StaticResource WelcomePageTextBox}"/>
                </Grid>
                <Button 
                Grid.Row="0" 
                x:Name="Registration" 
                Content="Зерегестрироваться" 
                Click="Registration_Click"
                Style="{StaticResource WelcomePageButton}"/>
                <Button 
                Grid.Row="1" 
                x:Name="Authorization" 
                Content="Уже есть аккаунт?" 
                Click="Authorization_Click"
                Style="{StaticResource WelcomePageButton}"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
