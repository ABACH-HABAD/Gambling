<Application x:Class="GamblingWpfUser.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:GamblingWpfUser"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <Style TargetType="Grid" x:Key="WelcomePageGrid">
            <Setter Property="Margin" Value="0,5,0,5"/>
        </Style>
        <Style TargetType="Button" x:Key="WelcomePageButton">
            <Setter Property="Margin" Value="0,5,0,5"/>
            <Setter Property="FontSize" Value="25"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="WelcomePageTextBlock">
            <Setter Property="FontSize" Value="25"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="TextBox" x:Key="WelcomePageTextBox">
            <Setter Property="FontSize" Value="25"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="Width" Value="300"/>
        </Style>
        <Style TargetType="PasswordBox" x:Key="WelcomePagePasswordBox">
            <Setter Property="FontSize" Value="25"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="Width" Value="300"/>
        </Style>
        <Style TargetType="Button" x:Key="ImageButtonStyle" >
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="15"
                        RenderTransformOrigin="0.5,0.5"
                        Cursor="Hand">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="borderScale"/>
                            </Border.RenderTransform>
                            <Grid>
                                <ContentPresenter 
                                        Margin="{TemplateBinding Padding}"
                                        x:Name="contentPresenter"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          RenderTransformOrigin="0.5,0.5">
                                    <ContentPresenter.RenderTransform>
                                        <ScaleTransform x:Name="contentScale"/>
                                    </ContentPresenter.RenderTransform>
                                </ContentPresenter>
                                <Border x:Name="hoverOverlay" 
                                        Background="#33FFFFFF" 
                                        Opacity="0"
                                        CornerRadius="15"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="contentScale"
                                 Storyboard.TargetProperty="ScaleX"
                                 To="1.05" Duration="0:0:0.15"/>
                                        <DoubleAnimation Storyboard.TargetName="contentScale"
                                 Storyboard.TargetProperty="ScaleY"
                                 To="1.05" Duration="0:0:0.15"/>
                                        <DoubleAnimation Storyboard.TargetName="hoverOverlay"
                                 Storyboard.TargetProperty="Opacity"
                                 To="0.5" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>

                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="contentScale"
                                 Storyboard.TargetProperty="ScaleX"
                                 To="1.0" Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="contentScale"
                                 Storyboard.TargetProperty="ScaleY"
                                 To="1.0" Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="hoverOverlay"
                                 Storyboard.TargetProperty="Opacity"
                                 To="0" Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>

                            <EventTrigger RoutedEvent="PreviewMouseLeftButtonDown">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="borderScale"
                                 Storyboard.TargetProperty="ScaleX"
                                 To="0.95" Duration="0:0:0.05"/>
                                        <DoubleAnimation Storyboard.TargetName="borderScale"
                                 Storyboard.TargetProperty="ScaleY"
                                 To="0.95" Duration="0:0:0.05"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>

                            <EventTrigger RoutedEvent="PreviewMouseLeftButtonUp">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="borderScale"
                                 Storyboard.TargetProperty="ScaleX"
                                 To="1" Duration="0:0:0.05"/>
                                        <DoubleAnimation Storyboard.TargetName="borderScale"
                                 Storyboard.TargetProperty="ScaleY"
                                 To="1" Duration="0:0:0.05"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button" x:Key="GamePageButton" BasedOn="{StaticResource ImageButtonStyle}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="5"/>
            <Setter Property="BorderBrush" Value="#FF160B3C" />
            <Setter Property="Background" Value="#FF9779AD" />
            <Setter Property="Margin" Value="20"/>
            <Setter Property="Padding" Value="15"/>
        </Style>
        <Style TargetType="Button" x:Key="HeaderButton" BasedOn="{StaticResource ImageButtonStyle}">
            <Setter Property="Background" Value="#FF549CBB"/>
            <Setter Property="BorderBrush" Value="#FF0B0C3A"/>
            <Setter Property="BorderThickness" Value="5"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="FontSize" Value="18"/>
        </Style>
        <Style TargetType="Button" x:Key="ProfileButton" BasedOn="{StaticResource ImageButtonStyle}">
            <Setter Property="Background" Value="#FF2ED4D8"/>
            <Setter Property="BorderBrush" Value="#FF1A1440"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Margin" Value="5"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="ProfileTextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Margin" Value="5"/>
        </Style>
        <Style TargetType="TextBox" x:Key="ProfileTextBox">
            <Setter Property="Background" Value="#FF2ED4D8"/>
            <Setter Property="BorderBrush" Value="#FF1A1440"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Margin" Value="5"/>
        </Style>
        <Style TargetType="RadioButton" x:Key="ProfileRadioButton">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Margin" Value="5"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="PayPageTextBlock">
            <Setter Property="FontSize" Value="25"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Bottom"/>
        </Style>
        <Style TargetType="TextBox" x:Key="PayPageTextBox">
            <Setter Property="FontSize" Value="25"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="MaxHeight" Value="35"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="#FF77C3BA"/>
        </Style>
        <Style TargetType="Button" x:Key="PayPageButton">
            <Setter Property="FontSize" Value="25"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="MaxHeight" Value="50"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="#FF77C3BA"/>
        </Style>
        <Style TargetType="Button" x:Key="BetButton" BasedOn="{StaticResource ImageButtonStyle}">
            <Setter Property="Padding" Value="1"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="FontFamily" Value="Goudy Stout" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="Yellow"/>
            <Setter Property="Background" Value="Red"/>
            <Setter Property="BorderBrush" Value="Yellow"/>
        </Style>
        <Style TargetType="DataGrid" x:Key="CustomDataGridStyle">
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="CanUserReorderColumns" Value="True"/>
            <Setter Property="CanUserResizeColumns" Value="True"/>
            <Setter Property="CanUserSortColumns" Value="True"/>
            <Setter Property="GridLinesVisibility" Value="All"/>
            <Setter Property="HorizontalGridLinesBrush" Value="White"/>
            <Setter Property="VerticalGridLinesBrush" Value="White"/>
            <Setter Property="Background" Value="#FF115D20"/>
            <Setter Property="AlternatingRowBackground" Value="#FF015432"/>
            <Setter Property="RowBackground" Value="#FF09502A"/>
            <Setter Property="BorderBrush" Value="#FF003D23"/>
            <Setter Property="BorderThickness" Value="3"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="DarkGreen"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Height" Value="35"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="BorderBrush" Value="DarkOliveGreen"/>
                        <Setter Property="BorderThickness" Value="2"/>
                        <Setter Property="Padding" Value="5"/>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="RowStyle">
                <Setter.Value>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Height" Value="32"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                        <Setter Property="BorderBrush" Value="#FF015432"/>
                        <Setter Property="BorderThickness" Value="2"/>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="CellStyle">
                <Setter.Value>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                        <Setter Property="Padding" Value="8,4"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Focusable" Value="False"/>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button" x:Key="GameButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
            Background="{TemplateBinding Background}"
            BorderBrush="{TemplateBinding BorderBrush}"
            BorderThickness="{TemplateBinding BorderThickness}"
            RenderTransformOrigin="0.5,0.5"
            Cursor="Hand">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="borderScale"/>
                            </Border.RenderTransform>
                            <Grid>
                                <ContentPresenter 
                            Margin="{TemplateBinding Padding}"
                            x:Name="contentPresenter"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              RenderTransformOrigin="0.5,0.5">
                                    <ContentPresenter.RenderTransform>
                                        <ScaleTransform x:Name="contentScale"/>
                                    </ContentPresenter.RenderTransform>
                                </ContentPresenter>
                                <Border x:Name="hoverOverlay" 
                            Background="#8FFFFF88" 
                            Opacity="0"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="contentScale"
                     Storyboard.TargetProperty="ScaleX"
                     To="1.05" Duration="0:0:0.15"/>
                                        <DoubleAnimation Storyboard.TargetName="contentScale"
                     Storyboard.TargetProperty="ScaleY"
                     To="1.05" Duration="0:0:0.15"/>
                                        <DoubleAnimation Storyboard.TargetName="hoverOverlay"
                     Storyboard.TargetProperty="Opacity"
                     To="0.5" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>

                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="contentScale"
                     Storyboard.TargetProperty="ScaleX"
                     To="1.0" Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="contentScale"
                     Storyboard.TargetProperty="ScaleY"
                     To="1.0" Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="hoverOverlay"
                     Storyboard.TargetProperty="Opacity"
                     To="0" Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>

                            <EventTrigger RoutedEvent="PreviewMouseLeftButtonDown">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="borderScale"
                     Storyboard.TargetProperty="ScaleX"
                     To="0.95" Duration="0:0:0.05"/>
                                        <DoubleAnimation Storyboard.TargetName="borderScale"
                     Storyboard.TargetProperty="ScaleY"
                     To="0.95" Duration="0:0:0.05"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>

                            <EventTrigger RoutedEvent="PreviewMouseLeftButtonUp">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="borderScale"
                     Storyboard.TargetProperty="ScaleX"
                     To="1" Duration="0:0:0.05"/>
                                        <DoubleAnimation Storyboard.TargetName="borderScale"
                     Storyboard.TargetProperty="ScaleY"
                     To="1" Duration="0:0:0.05"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button" x:Key="Green" BasedOn="{StaticResource GameButton}">
            <Setter Property="Background" Value="Green"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style TargetType="Button" x:Key="Red" BasedOn="{StaticResource GameButton}">
            <Setter Property="Background" Value="Red"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style TargetType="Button" x:Key="Black" BasedOn="{StaticResource GameButton}">
            <Setter Property="Background" Value="Black"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

    </Application.Resources>
</Application>
