<Window x:Class="GamblingWpfUser.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GamblingWpfUser"
        mc:Ignorable="d"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Title="MainWindow" 
        MinHeight="450" MinWidth="800"
        Closed="OnClosed"
        Loaded="OnLoaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="6*"/>
        </Grid.RowDefinitions>
        <Grid 
            x:Name="ProfileInfo" 
            Visibility="Visible">
            <Grid.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FF21075D" Offset="1"/>
                    <GradientStop Color="#FF1F5C67" Offset="0.5"/>
                    <GradientStop Color="#FF21075D" Offset="0"/>
                </LinearGradientBrush>
            </Grid.Background>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Button 
                Grid.Row="0" 
                Margin="10,15,10,15" 
                Content="Вернуться на главную" 
                Name="Back" 
                HorizontalAlignment="Left" 
                Click="Back_Click" 
                HorizontalContentAlignment="Left"/>
            <Border 
                Grid.Column="1" 
                Margin="5" 
                Padding="5"
                Background="#FF549CBB"
                BorderThickness="5"
                CornerRadius="20"
                BorderBrush="#FF0B0C3A">
                <StackPanel 
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
                    <TextBlock Margin="5" x:Name="UserName" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <TextBlock Margin="5" x:Name="Balance" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <Button Margin="5" Content="Выйти" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
        <Frame 
            Name="MainFrame"
            Grid.Row="1"
            Navigated="MainFrame_Navigated">
            <Frame.NavigationUIVisibility>Hidden</Frame.NavigationUIVisibility>
        </Frame>
    </Grid>
</Window>
