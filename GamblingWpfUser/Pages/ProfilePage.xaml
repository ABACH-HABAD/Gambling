<Page x:Class="GamblingWpfUser.Pages.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:GamblingWpfUser.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Личный кабинет"
      Loaded="Page_Loaded">
    <Grid>
        <StackPanel Margin="25">
            <Grid Margin="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="10">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{StaticResource ProfileTextBlock}">
                            Баланс:
                        </TextBlock>
                        <TextBlock Style="{StaticResource ProfileTextBlock}" Grid.Column="1" x:Name="Balance"/>
                    </StackPanel>
                    <Button Name="AddToBalance" Content="Пополнить" Style="{StaticResource ProfileButton}" Click="AddToBalance_Click"/>
                    <Button Name="WhithdrawFromBalance" Content="Вывести" Style="{StaticResource ProfileButton}" Click="WhithdrawFromBalance_Click"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="10">
                    <TextBlock Style="{StaticResource ProfileTextBlock}">
                        Имя профиля:
                    </TextBlock>
                    <StackPanel Name="UserNamePanel" Visibility="Visible">
                        <TextBlock x:Name="UserName" Style="{StaticResource ProfileTextBlock}">
                        Никита Додеп                        </TextBlock>
                        <Button Name="ChangeName" Content="Сменить имя" Style="{StaticResource ProfileButton}" Click="ChangeName_Click"/>
                    </StackPanel>
                    <StackPanel Name="ChangeUserNamePanel"  Visibility="Collapsed">
                        <TextBox x:Name="ChangeUserName" Style="{StaticResource ProfileTextBox}">

                        </TextBox>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Name="ConfirmChangeName" Content="Подтвердить" Style="{StaticResource ProfileButton}" Click="ConfirmChangeName_Click"/>
                            <Button Grid.Column="1" Name="DenyChangeName" Content="Отменить" Style="{StaticResource ProfileButton}" Click="DenyChangeName_Click"/>
                        </Grid>
                    </StackPanel>
                    <Button Name="ChangeEmail" Content="Сменить электронную почту" Style="{StaticResource ProfileButton}" Click="ChangeEmail_Click"/>
                    <Button Name="ChangePassword" Content="Сменить пароль" Style="{StaticResource ProfileButton}" Click="ChangePassword_Click"/>
                </StackPanel>
            </Grid>
            <Border
                Margin="10"
                Padding="10"
                BorderBrush="Black"
                BorderThickness="3"
                CornerRadius="25" HorizontalAlignment="Center">
                <StackPanel>
                    <TextBlock
                        Style="{StaticResource ProfileTextBlock}"
                        HorizontalAlignment="Center">
                        Статистика:
                    </TextBlock>
                    <StackPanel Orientation="Horizontal">
                        <RadioButton  
                            Content="Всё" 
                            Name="All"
                            GroupName="GameTypes"
                            Style="{StaticResource ProfileRadioButton}" 
                            Checked="All_Checked"/>
                        <RadioButton  
                            Content="Слоты" 
                            Name="Slots"
                            GroupName="GameTypes"
                            Style="{StaticResource ProfileRadioButton}" 
                            Checked="Slots_Checked"/>
                        <RadioButton  
                            Content="Блэкджек" 
                            Name="Blackjack"
                            GroupName="GameTypes"
                            Style="{StaticResource ProfileRadioButton}" 
                            Checked="Blackjack_Checked"/>
                        <RadioButton  
                            Content="Рулетка" 
                            Name="Roulette"
                            GroupName="GameTypes"
                            Style="{StaticResource ProfileRadioButton}" 
                            Checked="Roulette_Checked"/>
                    </StackPanel>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource ProfileTextBlock}" Grid.Row="0" Grid.Column="1">
                                    Количество:
                        </TextBlock>
                        <TextBlock Style="{StaticResource ProfileTextBlock}" Grid.Row="0" Grid.Column="2">
                            Сумма:
                        </TextBlock>
                        <TextBlock Style="{StaticResource ProfileTextBlock}" Grid.Row="1" Grid.Column="0">
                             Победы:
                        </TextBlock>
                        <TextBlock 
                            Style="{StaticResource ProfileTextBlock}" 
                            Grid.Row="1"
                            Grid.Column="1" 
                            x:Name="WinCount">
                            10
                        </TextBlock>
                        <TextBlock 
                            Style="{StaticResource ProfileTextBlock}" 
                            Grid.Row="1" 
                            Grid.Column="2" 
                            x:Name="WinBalance">
                            500
                        </TextBlock>
                        <TextBlock Style="{StaticResource ProfileTextBlock}" Grid.Row="2" Grid.Column="0">
                              Поражения:
                        </TextBlock>
                        <TextBlock 
                            Style="{StaticResource ProfileTextBlock}"
                            Grid.Row="2"
                            Grid.Column="1"
                            x:Name="LossCount">
                            50
                        </TextBlock>
                        <TextBlock 
                            Style="{StaticResource ProfileTextBlock}" 
                            Grid.Row="2" 
                            Grid.Column="2" 
                            x:Name="LossBalance">
                            50000
                        </TextBlock>
                        <TextBlock Style="{StaticResource ProfileTextBlock}" Grid.Row="3" Grid.Column="0">
                              Итого:
                        </TextBlock>
                        <TextBlock 
                            Style="{StaticResource ProfileTextBlock}"
                            Grid.Row="3"
                            Grid.Column="1"
                            Name="WinFrequency">
                             % Побед: 67%
                        </TextBlock>
                        <TextBlock 
                            Style="{StaticResource ProfileTextBlock}"

                            Grid.Row="3"
                            Grid.Column="2"
                            Name="TotalBalance">
                             -49950
                        </TextBlock>
                    </Grid>
                </StackPanel>
            </Border>
            <Button Name="Logout" Style="{StaticResource ProfileButton}" Content="Выйти из аккаунта" Click="Logout_Click"/>
            <Button Name="DeleteAccount" Style="{StaticResource ProfileButton}" Content="Удалить аккаунт" Click="DeleteAccount_Click"/>
        </StackPanel>
    </Grid>
</Page>
