<Page x:Class="GamblingWpfUser.Pages.Games.RoulettePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:GamblingWpfUser.Pages.Games"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Рулетка">
    <Page.Resources>
        <Style TargetType="Button" x:Key="Green">
            <Setter Property="Background" Value="Green"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style TargetType="Button" x:Key="Red">
            <Setter Property="Background" Value="Red"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style TargetType="Button" x:Key="Black">
            <Setter Property="Background" Value="Black"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
    </Page.Resources>
    <Page.Background>
        <ImageBrush ImageSource="/Resources/Images/Roulette/bg-r.jpg"/>
    </Page.Background>
    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="7*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Panel.ZIndex="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="5*"/>
                <ColumnDefinition Width="6*"/>
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="3*"/>
                    <RowDefinition Height="16*"/>
                </Grid.RowDefinitions>
                <TextBlock x:Name="Number" HorizontalAlignment="Center" VerticalAlignment="Center">
                    Выпало число: 0
                </TextBlock>
                <Image x:Name="RouletteImage" Source="/Resources/Images/Roulette/Roulette.png" Grid.Row="1" Margin="10"/>
                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="2*"/>
                        <RowDefinition Height="9*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="13*"/>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="13*"/>
                    </Grid.ColumnDefinitions>
                    <Image  Grid.Column="1" Source="/Resources/Images/Roulette/Стрелка.png" Stretch="Fill" HorizontalAlignment="Center" VerticalAlignment="Center" Panel.ZIndex="1" />
                </Grid>
            </Grid>
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="6*"/>
                    <RowDefinition Height="10*"/>
                    <RowDefinition Height="3*"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="2*"/>
                        <RowDefinition Height="8*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Margin="0,5,0,5" VerticalAlignment="Bottom" HorizontalAlignment="Center">
                        Ваши ставки:
                    </TextBlock>
                    <ScrollViewer
                        Grid.Row="1" 
                        CanContentScroll="True" 
                        VerticalScrollBarVisibility="Auto" 
                        HorizontalScrollBarVisibility="Auto">
                        <DataGrid 
                            x:Name="Bids"
                            IsReadOnly="True"
                            CanUserAddRows="False"
                            CanUserDeleteRows="False"
                            AutoGenerateColumns="False" 
                            HorizontalAlignment="Center" 
                            BorderThickness="3"
                            BorderBrush="#FF003D23"
                            Background="#FF015432">
                            <DataGrid.Columns>
                                <DataGridTextColumn 
                                    Header="Тип ставки" 
                                    Binding="{Binding Type}" 
                                    CanUserSort="False"
                                    CanUserReorder="False"
                                    CanUserResize="False"/>
                                <DataGridTextColumn 
                                    Header="Сумма" 
                                    Binding="{Binding BidCount}"
                                    CanUserSort="False"
                                    CanUserReorder="False"
                                    CanUserResize="False"/>
                                <DataGridCheckBoxColumn
                                    Header="Отменить" 
                                    CanUserSort="False"
                                    CanUserReorder="False"
                                    CanUserResize="False"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </ScrollViewer>
                </Grid>
                <Grid Margin="20" Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="8*"/>
                        <RowDefinition Height="3*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="23*"/>
                        <ColumnDefinition Width="3*"/>
                    </Grid.ColumnDefinitions>
                    <Button Style="{StaticResource Green}" Grid.Column="0" Grid.Row="0" Content="0" Name="Zero" Click="Number_Click"/>
                    <Grid Grid.Row="0" Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="Number1" Style="{StaticResource Red}" Content="1" Grid.Column="0" Grid.Row="2" Click="Number_Click"/>
                        <Button x:Name="Number2" Style="{StaticResource Black}" Content="2" Grid.Column="0" Grid.Row="1" Click="Number_Click"/>
                        <Button x:Name="Number3" Style="{StaticResource Red}" Content="3" Grid.Column="0" Grid.Row="0" Click="Number_Click"/>
                        <Button x:Name="Number4" Style="{StaticResource Black}"  Content="4" Grid.Column="1" Grid.Row="2" Click="Number_Click"/>
                        <Button x:Name="Number5" Style="{StaticResource Red}" Content="5" Grid.Column="1" Grid.Row="1" Click="Number_Click"/>
                        <Button x:Name="Number6" Style="{StaticResource Black}" Content="6" Grid.Column="1" Grid.Row="0" Click="Number_Click" />
                        <Button x:Name="Number7" Style="{StaticResource Red}" Content="7" Grid.Column="2" Grid.Row="2" Click="Number_Click" />
                        <Button x:Name="Number8" Style="{StaticResource Black}" Content="8" Grid.Column="2" Grid.Row="1" Click="Number_Click"/>
                        <Button x:Name="Number9" Style="{StaticResource Red}" Content="9" Grid.Column="2" Grid.Row="0" Click="Number_Click" />
                        <Button x:Name="Number10" Style="{StaticResource Black}" Content="10" Grid.Column="3" Grid.Row="2" Click="Number_Click"/>
                        <Button x:Name="Number11" Style="{StaticResource Black}" Content="11" Grid.Column="3" Grid.Row="1" Click="Number_Click"/>
                        <Button x:Name="Number12" Style="{StaticResource Red}" Content="12" Grid.Column="3" Grid.Row="0" Click="Number_Click"/>
                        <Button x:Name="Number13" Style="{StaticResource Black}" Content="13" Grid.Column="4" Grid.Row="2" Click="Number_Click"/>
                        <Button x:Name="Number14" Style="{StaticResource Red}" Content="14" Grid.Column="4" Grid.Row="1" Click="Number_Click"/>
                        <Button x:Name="Number15" Style="{StaticResource Black}" Content="15" Grid.Column="4" Grid.Row="0" Click="Number_Click"/>
                        <Button x:Name="Number16" Style="{StaticResource Red}" Content="16" Grid.Column="5" Grid.Row="2" Click="Number_Click"/>
                        <Button x:Name="Number17" Style="{StaticResource Black}" Content="17" Grid.Column="5" Grid.Row="1" Click="Number_Click"/>
                        <Button x:Name="Number18" Style="{StaticResource Red}" Content="18" Grid.Column="5" Grid.Row="0" Click="Number_Click"/>
                        <Button x:Name="Number19" Style="{StaticResource Black}" Content="19" Grid.Column="6" Grid.Row="2" Click="Number_Click"/>
                        <Button x:Name="Number20" Style="{StaticResource Red}" Content="20" Grid.Column="6" Grid.Row="1" Click="Number_Click"/>
                        <Button x:Name="Number21" Style="{StaticResource Red}" Content="21" Grid.Column="6" Grid.Row="0" Click="Number_Click"/>
                        <Button x:Name="Number22" Style="{StaticResource Black}" Content="22" Grid.Column="7" Grid.Row="2" Click="Number_Click"/>
                        <Button x:Name="Number23" Style="{StaticResource Red}" Content="23" Grid.Column="7" Grid.Row="1" Click="Number_Click"/>
                        <Button x:Name="Number24" Style="{StaticResource Black}" Content="24" Grid.Column="7" Grid.Row="0" Click="Number_Click"/>
                        <Button x:Name="Number25" Style="{StaticResource Red}" Content="25" Grid.Column="8" Grid.Row="2" Click="Number_Click"/>
                        <Button x:Name="Number26" Style="{StaticResource Black}" Content="26" Grid.Column="8" Grid.Row="1" Click="Number_Click"/>
                        <Button x:Name="Number27" Style="{StaticResource Red}" Content="27" Grid.Column="8" Grid.Row="0" Click="Number_Click"/>
                        <Button x:Name="Number28" Style="{StaticResource Black}" Content="28" Grid.Column="9" Grid.Row="2" Click="Number_Click"/>
                        <Button x:Name="Number29" Style="{StaticResource Black}" Content="29" Grid.Column="9" Grid.Row="1" Click="Number_Click"/>
                        <Button x:Name="Number30" Style="{StaticResource Red}" Content="30" Grid.Column="9" Grid.Row="0" Click="Number_Click"/>
                        <Button x:Name="Number31" Style="{StaticResource Black}" Content="31" Grid.Column="10" Grid.Row="2" Click="Number_Click"/>
                        <Button x:Name="Number32" Style="{StaticResource Red}" Content="32" Grid.Column="10" Grid.Row="1" Click="Number_Click"/>
                        <Button x:Name="Number33" Style="{StaticResource Black}" Content="33" Grid.Column="10" Grid.Row="0" Click="Number_Click"/>
                        <Button x:Name="Number34" Style="{StaticResource Red}" Content="34" Grid.Column="11" Grid.Row="2" Click="Number_Click"/>
                        <Button x:Name="Number35" Style="{StaticResource Black}" Content="35" Grid.Column="11" Grid.Row="1" Click="Number_Click"/>
                        <Button x:Name="Number36" Style="{StaticResource Red}" Content="36" Grid.Column="11" Grid.Row="0" Click="Number_Click"/>
                    </Grid>
                    <Grid Grid.Row="0" Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <Button Style="{StaticResource Green}" Grid.Row="0" Content="2 to 1" Name="ThirdColumn" Click="ThirdColumn_Click"/>
                        <Button Style="{StaticResource Green}" Grid.Row="1" Content="2 to 1" Name="SecondColumn" Click="SecondColumn_Click"/>
                        <Button Style="{StaticResource Green}" Grid.Row="2" Content="2 to 1" Name="FirstColumn" Click="FirstColumn_Click"/>
                    </Grid>
                    <Grid Grid.Row="1" Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <Button Style="{StaticResource Green}" Grid.Column="0" Content="1 st 12" Name="First12" Click="First12_Click"/>
                        <Button Style="{StaticResource Green}" Grid.Column="1" Content="2 nd 12" Name="Second12" Click="Second12_Click"/>
                        <Button Style="{StaticResource Green}" Grid.Column="2" Content="3 rd 12" Name="Third12" Click="Third12_Click"/>
                        <Grid Grid.Row="1" Grid.Column="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <Button Style="{StaticResource Green}" Grid.Column="0" Content="1 to 18" Name="FirstHalf" Click="FirstHalf_Click"/>
                            <Button Style="{StaticResource Green}" Grid.Column="1" Content="EVEN" Name="Even" Click="Even_Click"/>
                        </Grid>
                        <Grid Grid.Row="1" Grid.Column="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <Button Style="{StaticResource Red}" Grid.Column="0" Name="Red" Click="Red_Click"/>
                            <Button Style="{StaticResource Black}" Grid.Column="1" Name="Black" Click="Black_Click"/>
                        </Grid>
                        <Grid Grid.Row="1" Grid.Column="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <Button Style="{StaticResource Green}" Grid.Column="0" Content="ODD" Name="Odd" Click="Odd_Click"/>
                            <Button Style="{StaticResource Green}" Grid.Column="1" Content="19 to 36" Name="SecondHalf" Click="SecondHalf_Click"/>
                        </Grid>
                    </Grid>
                </Grid>
                <Grid Grid.Row="2" Margin="5,20,5,20" >
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="10*"/>
                        <ColumnDefinition Width="15*"/>
                        <ColumnDefinition Width="15*"/>
                        <ColumnDefinition Width="15*"/>
                        <ColumnDefinition Width="15*"/>
                        <ColumnDefinition Width="15*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock 
                        Grid.Column="0" 
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center" 
                        Margin="0,0,5,0">
                        Выбрано:
                    </TextBlock>
                    <TextBlock 
                        x:Name="Selected" 
                        Grid.Column="1" 
                        HorizontalAlignment="Left" 
                        VerticalAlignment="Center"/>
                    <TextBlock 
                        Grid.Column="2" 
                        HorizontalAlignment="Right" 
                        VerticalAlignment="Center" Margin="0,0,5,0">
                        Поставлено:
                    </TextBlock>
                    <TextBox 
                        x:Name="Bid" 
                        Grid.Column="3" 
                        VerticalContentAlignment="Center"
                        Margin="5,0,5,0"/>
                    <Button 
                        x:Name="Accept" 
                        Content="Поставить" 
                        Grid.Column="4" 
                        Click="Accept_Click"
                        Margin="5,0,5,0"/>
                    <Button 
                        x:Name="LastBid"
                        Content="Повторить ставку" 
                        Grid.Column="5" 
                        Click="LastBid_Click" 
                        Margin="5,0,5,0"/>
                </Grid>
            </Grid>
        </Grid>
        <Button 
            Grid.Row="1" 
            Content="Крутить!" 
            Name="Spin" 
            Click="Spin_Click" 
            Margin="100,10,100,10"
            FontWeight="Bold"
            FontSize="16"
            BorderThickness="5"
            BorderBrush="Yellow"
            Background="Red"
            Foreground="Yellow" />
    </Grid>
</Page>
