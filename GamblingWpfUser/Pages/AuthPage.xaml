<Page x:Class="GamblingWpfUser.Pages.AuthPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:GamblingWpfUser.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Страница авторизации">

    <Grid>
        <Border
            CornerRadius="25"
            BorderThickness="3" 
            BorderBrush="Black" 
            HorizontalAlignment="Center"
            VerticalAlignment="Center">
            <StackPanel 
                Margin="15"
            Width="450"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">
                <Grid Style="{StaticResource WelcomePageGrid}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock 
                    Text="Логин" 
                    Style="{StaticResource WelcomePageTextBlock}"/>
                    <TextBox
                    Grid.Column="1"
                    Name="Login"
                    Style="{StaticResource WelcomePageTextBox}"/>
                </Grid>
                <Grid Style="{StaticResource WelcomePageGrid}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock 
                    Text="Пароль"
                    Style="{StaticResource WelcomePageTextBlock}"/>
                    <PasswordBox 
                    Name="Password" 
                    Grid.Column="1"
                    Style="{StaticResource WelcomePagePasswordBox}"/>
                </Grid>
                <Border
                    CornerRadius="10"
                    BorderThickness="2" 
                    BorderBrush="Black" 
                    Margin="0,5,0,5"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                    <TextBlock 
                        x:Name="CaptchaPlace" 
                        FontSize="25"
                        HorizontalAlignment="Center"
                        Margin="5">
                        Капча
                    </TextBlock>
                </Border>

                <Grid Style="{StaticResource WelcomePageGrid}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock 
                    Text="Капча"
                    Style="{StaticResource WelcomePageTextBlock}"/>
                    <TextBox 
                    Name="CaptchaAnswer" 
                    Grid.Column="1"
                    Style="{StaticResource WelcomePageTextBox}"/>
                </Grid>
                <Button 
                Grid.Row="0" 
                x:Name="Authorization" 
                Content="Войти" 
                Click="Authorization_Click"
                Style="{StaticResource WelcomePageButton}"/>
                <Button 
                Grid.Row="1" 
                x:Name="Registration" 
                Content="Нет аккаунта?" 
                Click="Registration_Click"
                Style="{StaticResource WelcomePageButton}"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
